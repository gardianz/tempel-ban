# Temple REST API key
TEMPLE_API_KEY=

# Loop wallet (server-mode signing)
LOOP_PRIVATE_KEY=
LOOP_PARTY_ID=

# mainnet | testnet
NETWORK=testnet

# Optional Telegram notifications (omit to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Proxy pool for the wallet/deposit path (Cantonloop blocks datacenter IPs).
# Easiest: put one proxy URL per line in ./proxy.txt (copy from proxy.txt.example).
# These env vars are alternatives/additions — all sources are merged + deduped.
# PROXY_FILE=proxy.txt          # override the default proxy.txt path
# PROXY_URL=                    # a single proxy
# PROXY_LIST=                   # comma/newline-separated pool
# PROXY_SCOPE=wallet            # wallet (default) | all
